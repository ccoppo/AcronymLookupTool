<Window x:Class="AcronymLookup.UI.ApprovalQueueWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Approval Queue"
        Width="720"
        Height="520"
        MinWidth="600"
        MinHeight="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#F8F9FA">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="*"/>     <!-- Master / Detail -->
            <RowDefinition Height="Auto"/>  <!-- Footer / Close -->
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#E9ECEF"
                BorderBrush="#DEE2E6"
                BorderThickness="0,0,0,1"
                Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Approval Queue"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#212529"/>
                    <TextBlock Name="SubtitleText"
                               Text="Review pending term requests for this project"
                               FontSize="12"
                               Foreground="#6C757D"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Pending count badge -->
                <Border Grid.Column="1"
                        Name="CountBadge"
                        Background="#007BFF"
                        CornerRadius="12"
                        Padding="12,4"
                        VerticalAlignment="Center">
                    <TextBlock Name="PendingCountText"
                               Text="0 pending"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="White"/>
                </Border>
            </Grid>
        </Border>

        <!-- MASTER / DETAIL -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>                 <!-- Master list -->
                <ColumnDefinition Width="Auto"/>               <!-- Divider -->
                <ColumnDefinition Width="*"/>                  <!-- Detail panel -->
            </Grid.ColumnDefinitions>

            <!-- MASTER: Request List  -->
            <Border Grid.Column="0"
                    BorderBrush="#DEE2E6"
                    BorderThickness="0,0,1,0"
                    Background="#FFFFFF">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Request list -->
                    <ListBox Grid.Row="0"
                             Name="RequestListBox"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             SelectionChanged="RequestListBox_SelectionChanged">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#E7F3FF"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F1F3F5"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12,10"
                                        BorderBrush="#DEE2E6"
                                        BorderThickness="0,0,0,1">
                                    <StackPanel>
                                        <!-- Request type badge + abbreviation -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <Border Name="TypeBadge"
                                                    CornerRadius="3"
                                                    Padding="5,2"
                                                    Margin="0,0,6,0"
                                                    VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding RequestType}" Value="Add">
                                                                <Setter Property="Background" Value="#28A745"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding RequestType}" Value="Edit">
                                                                <Setter Property="Background" Value="#007BFF"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding RequestType}" Value="Delete">
                                                                <Setter Property="Background" Value="#DC3545"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding RequestType}"
                                                           FontSize="10"
                                                           FontWeight="SemiBold"
                                                           Foreground="White"/>
                                            </Border>
                                            <TextBlock Text="{Binding DisplayAbbreviation}"
                                                       FontSize="13"
                                                       FontWeight="Bold"
                                                       Foreground="#212529"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <!-- Requester -->
                                        <TextBlock Text="{Binding RequestedByUserName}"
                                                   FontSize="11"
                                                   Foreground="#495057"/>

                                        <!-- Date -->
                                        <TextBlock Text="{Binding DateRequested, StringFormat='MMM d, yyyy'}"
                                                   FontSize="11"
                                                   Foreground="#6C757D"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Empty state -->
                    <TextBlock Grid.Row="0"
                               Name="EmptyStateText"
                               Text="No pending requests"
                               FontSize="13"
                               Foreground="#6C757D"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="Collapsed"/>
                </Grid>
            </Border>

            <!-- DETAIL: Selected Request  -->
            <ScrollViewer Grid.Column="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <Grid Name="DetailPanel" Margin="20" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- Term + badge -->
                        <RowDefinition Height="Auto"/>  <!-- Definition -->
                        <RowDefinition Height="Auto"/>  <!-- Category -->
                        <RowDefinition Height="Auto"/>  <!-- Notes -->
                        <RowDefinition Height="Auto"/>  <!-- Reason -->
                        <RowDefinition Height="Auto"/>  <!-- Requester info -->
                        <RowDefinition Height="Auto"/>  <!-- Divider -->
                        <RowDefinition Height="Auto"/>  <!-- Review comment -->
                        <RowDefinition Height="Auto"/>  <!-- Approve / Reject buttons -->
                    </Grid.RowDefinitions>

                    <!-- Term + request type badge -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Name="DetailAbbreviation"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="#212529"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>
                        <Border Name="DetailTypeBadge"
                                CornerRadius="4"
                                Padding="8,3"
                                VerticalAlignment="Center">
                            <TextBlock Name="DetailTypeText"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="White"/>
                        </Border>
                    </StackPanel>

                    <!-- Definition -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,12">
                        <TextBlock Text="Definition"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#6C757D"
                                   Margin="0,0,0,4"/>
                        <TextBlock Name="DetailDefinition"
                                   FontSize="14"
                                   Foreground="#212529"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Category -->
                    <StackPanel Grid.Row="2"
                                Name="DetailCategoryPanel"
                                Margin="0,0,0,12"
                                Visibility="Collapsed">
                        <TextBlock Text="Category"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#6C757D"
                                   Margin="0,0,0,4"/>
                        <TextBlock Name="DetailCategory"
                                   FontSize="14"
                                   Foreground="#212529"/>
                    </StackPanel>

                    <!-- Notes -->
                    <StackPanel Grid.Row="3"
                                Name="DetailNotesPanel"
                                Margin="0,0,0,12"
                                Visibility="Collapsed">
                        <TextBlock Text="Notes"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#6C757D"
                                   Margin="0,0,0,4"/>
                        <TextBlock Name="DetailNotes"
                                   FontSize="14"
                                   Foreground="#212529"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Request Reason -->
                    <StackPanel Grid.Row="4"
                                Name="DetailReasonPanel"
                                Margin="0,0,0,12"
                                Visibility="Collapsed">
                        <TextBlock Text="Reason for Request"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#6C757D"
                                   Margin="0,0,0,4"/>
                        <Border Background="#FFF9E6"
                                BorderBrush="#FFE08A"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="10,8">
                            <TextBlock Name="DetailReason"
                                       FontSize="13"
                                       Foreground="#856404"
                                       TextWrapping="Wrap"
                                       FontStyle="Italic"/>
                        </Border>
                    </StackPanel>

                    <!-- Requester info -->
                    <Border Grid.Row="5"
                            Background="#F1F3F5"
                            BorderBrush="#DEE2E6"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="10,8"
                            Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Requested by "
                                       FontSize="12"
                                       Foreground="#6C757D"/>
                            <TextBlock Name="DetailRequester"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#495057"/>
                            <TextBlock Text=" on "
                                       FontSize="12"
                                       Foreground="#6C757D"/>
                            <TextBlock Name="DetailDate"
                                       FontSize="12"
                                       Foreground="#495057"/>
                        </StackPanel>
                    </Border>

                    <!-- Divider -->
                    <Border Grid.Row="6"
                            Height="1"
                            Background="#DEE2E6"
                            Margin="0,0,0,16"/>

                    <!-- Review Comment -->
                    <StackPanel Grid.Row="7" Margin="0,0,0,16">
                        <TextBlock Text="Review Comment (Optional)"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#6C757D"
                                   Margin="0,0,0,6"/>
                        <TextBox Name="ReviewCommentInput"
                                 Height="60"
                                 FontSize="13"
                                 Padding="8,6"
                                 BorderBrush="#CED4DA"
                                 BorderThickness="1"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"/>
                    </StackPanel>

                    <!-- Approve / Reject -->
                    <Grid Grid.Row="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Name="ApproveButton"
                                Content="Approve"
                                Height="38"
                                Background="#28A745"
                                Foreground="White"
                                BorderThickness="0"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Cursor="Hand"
                                Click="ApproveButton_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#218838"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Grid.Column="2"
                                Name="RejectButton"
                                Content="Reject"
                                Height="38"
                                Background="#DC3545"
                                Foreground="White"
                                BorderThickness="0"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Cursor="Hand"
                                Click="RejectButton_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#C82333"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Grid>
            </ScrollViewer>

            <!-- No-selection placeholder -->
            <TextBlock Grid.Column="2"
                       Name="NoSelectionText"
                       Text="Select a request from the list to review it"
                       FontSize="13"
                       Foreground="#6C757D"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- FOOTER -->
        <Border Grid.Row="2"
                Background="#E9ECEF"
                BorderBrush="#DEE2E6"
                BorderThickness="0,1,0,0"
                Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Name="FooterStatusText"
                           Text=""
                           FontSize="12"
                           Foreground="#6C757D"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="1"
                        Name="CloseButton"
                        Content="Close"
                        Width="90"
                        Height="34"
                        Background="#6C757D"
                        Foreground="White"
                        BorderThickness="0"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Click="CloseButton_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#5A6268"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
